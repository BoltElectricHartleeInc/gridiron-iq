// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../server/src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DraftSession {
  id          String      @id @default(cuid())
  teamId      String
  teamName    String
  status      String      @default("in_progress") // in_progress | completed
  startedAt   DateTime    @default(now())
  completedAt DateTime?
  grade       String? // letter grade e.g. "A", "B+"
  gradeScore  Int? // numeric score
  picks       DraftPick[]
}

model DraftPick {
  id               String       @id @default(cuid())
  sessionId        String
  session          DraftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overall          Int
  round            Int
  pickInRound      Int
  teamId           String
  teamName         String
  prospectId       String
  prospectName     String
  prospectPosition String
  prospectGrade    Int
  isUserPick       Boolean      @default(false)
  isTrade          Boolean      @default(false)
  createdAt        DateTime     @default(now())
}

model GameResult {
  id           String   @id @default(cuid())
  homeTeamId   String
  homeTeamName String
  homeScore    Int
  awayTeamId   String
  awayTeamName String
  awayScore    Int
  league       String // NFL | NCAA
  playedAt     DateTime @default(now())
}

model ScoutingReport {
  id           String   @id @default(cuid())
  prospectId   String
  prospectName String
  report       String
  createdAt    DateTime @default(now())
}
